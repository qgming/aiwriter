{
  "name": "aiwriter",
  "private": true,
  "version": "0.9.4",
  "type": "module",
  "description": "神笔写作",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "vue-tsc -b && vite build && electron-builder --publish never",
    "dist": "electron-builder --win nsis --publish never",
    "release:github": "electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/jszip": "^3.4.0",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.2.0",
    "echarts": "^5.6.0",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^0.542.0",
    "marked": "^16.3.0",
    "openai": "^5.20.3",
    "pinia": "^3.0.3",
    "tailwindcss": "^4.1.13",
    "vue": "^3.5.18",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron": "^1.4.38",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.0.5"
  },
  "main": "dist-electron/main.js",
  "homepage": "./",
  "author": {
    "name": "MING",
    "email": "qgming@qq.com"
  },
  "build": {
    "appId": "com.qgming.aiwriter",
    "productName": "神笔写作",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "神笔写作",
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico",
      "installerHeaderIcon": "public/logo.ico"
    },
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/build/Release",
        "to": "better-sqlite3"
      },
      {
        "from": "resources/vec0.dll",
        "to": "vec0.dll"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "qgming",
      "repo": "aiwriter",
      "releaseType": "release"
    },
    "artifactName": "aiwriter-setup-${version}.${ext}"
  }
}
